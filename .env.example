# ============================================================
# SCOLANGO — Configuration d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS COMMITTER .env.local dans le dépôt Git
# ============================================================

# Clé API Gemini (obligatoire pour le module IA)
GEMINI_API_KEY="votre_cle_gemini_ici"

# URL de déploiement de l'application
APP_URL="http://localhost:3000"

# Mode NODE (development | production)
NODE_ENV="development"

# Secret JWT pour les sessions utilisateurs (générez avec: openssl rand -base64 64)
JWT_SECRET="changez_ce_secret_jwt_en_production_minimum_32_caracteres"

# Durée de validité des tokens JWT (ex: 8h, 1d, 7d)
JWT_EXPIRES_IN="8h"

# Activer le mode démo (true = quick-login visible, false = production)
DEMO_MODE="true"

# Port du serveur (défaut: 3000)
PORT=3000
